# Environment variables for LLM Evaluation Framework
# Copy this file to .env and fill in your values

# OpenAI API Key for chatbot queries
OPENAI_API_KEY=your_openai_api_key_here

# Log level for loguru (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=ERROR
CUSTOM_LOG_LEVEL=INFO

ENHANCED_ATTACK_ERROR_THRESHOLD_PERCENT=40

ATTACKS_PER_VULNERABILITY_TYPE=5

LOCAL_MODEL_ID=CHANGE_ME_OR_COMMENT_OUT_IF_NOT_USED

DEFAULT_SIMULATOR_MODEL=gpt-3.5-turbo-0125
DEFAULT_EVAL_MODEL=gpt-4o

# PostgreSQL configuration for vector store
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vectordb

# DeepEval Config
DEEPEVAL_PER_ATTEMPT_TIMEOUT_SECONDS_OVERRIDE=240

#Guardrails AI
GURADRAILS_AI_TOKEN=your_token

# LlamaFirewall

HF_HOME=some_value
TOGETHER_API_KEY=your_together_api_key_here

# Lakera Guard
LAKERA_GUARD_API_KEY=your_lakera_guard_api_key_here
LAKERA_GUARD_PROJECT_ID=your_lakera_guard_project_id_here
LAKERA_GUARD_TIMEOUT_SECONDS=60

# GCP Model Armor
GCP_MODEL_ARMOR_LOCATION=us-central1
GCP_MODEL_ARMOR_PROJECT_ID=your_gcp_project_id_here
GCP_MODEL_ARMOR_TEMPLATE_ID=your_gcp_model_armor_template_id_here
