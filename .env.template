# Environment variables for thesis-llm-chatbot-protection
# Copy this file to .env and fill in your values

# OpenAI API Key for chatbot queries
OPENAI_API_KEY=your_openai_api_key_here

# Log level for loguru (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

ENHANCED_ATTACK_ERROR_THRESHOLD_PERCENT=40

ATTACKS_PER_VULNERABILITY_TYPE=10

LOCAL_MODEL_ID=CHANGE_ME_OR_COMMENT_OUT_IF_NOT_USED

DEFAULT_SIMULATOR_MODEL=gpt-3.5-turbo-0125
DEFAULT_EVAL_MODEL=gpt-4o

# PostgreSQL configuration for vector store
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vectordb

#Guardrails AI
GURADRAILS_AI_TOKEN=your_token

# LlamaFirewall

HF_HOME=some_value
TOGETHER_API_KEY=some_value
