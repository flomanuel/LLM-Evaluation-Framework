@startuml
!theme plain
top to bottom direction
skinparam componentStyle rectangle

title LLM Chatbot Protection Framework - Current Runtime Architecture

package "CLI" {
'    [llm-test-baseline\n(cli.main)] as CLI
    [run-baseline] as RunBaseline
    [populate-db] as PopulateDb
    [summarize-run] as SummarizeRun
}

package "Test Orchestration" {
    [DefaultTest] as DefaultTest
    [Test.run / _execute_test_cases] as TestOrchestrator
    [BaseTestCase + concrete test cases] as TestCases
    [Attack builders\n(CSV-backed + DeepTeam-backed)] as AttackBuilders
    [AttackListEnhancer] as AttackEnhancer
    [ChatbotStore] as ChatbotStore
    [LangChainChatbot] as LangChainChatbot
    [GuardrailRunner] as GuardrailRunner
    [PromptHardeningGuardrail] as PromptHardeningGuardrail
    [LLMGuard] as LLMGuard
    [LlamaFirewall] as LlamaFirewall
    [LakeraGuard] as LakeraGuard
    [GuardrailsAI] as GuardrailsAI
    [GcpModelArmor] as GcpModelArmor
    [Storage helpers] as Storage
    [Run Summary Builder] as RunSummary
}

package "RAG + Document Path" {
    [DocumentLoader] as DocumentLoader
    [VectorStore] as VectorStore
    [PyPDF attack document loader\ninside LangChainChatbot] as AttackDocumentLoader
    [generate_image tool] as GenerateImage
}

package "Utility Layer" {
    [CSVLoader] as CSVLoader
    [OllamaGenerator] as OllamaGenerator
}

package "External Libraries / Services" {
    [DeepTeam] as DeepTeam
    [DeepEval + GEval] as DeepEval
    [LangChain + ChatOpenAI] as LangChain
    [OpenAI API] as OpenAI
    [PGVector / langchain-postgres] as PGVectorLib
    [llm-guard library] as LLMGuardLib
    [LlamaFirewall library] as LlamaFirewallLib
    [Lakera Guard API] as LakeraAPI
    [Guardrails AI API\n(local Docker service)] as GuardrailsAPI
    [GCP Model Armor API] as GcpModelArmorAPI
    [PyPDFLoader] as PyPDFLoader
    [Postgres + pgvector] as Postgres
}

database "Project Data" {
    [CSV prompt files\n_prompt_files] as CsvFiles
    [Attack PDFs\n_attack_documents] as AttackDocs
    [RAG PDFs\n_rag_documents] as RagDocs
    [Run results JSON\n_runs/<run>/result.json] as RunResultJson
    [Per-testcase JSON\n_runs/<run>/testcase/*.json] as TestcaseJson
    [Run summary JSON/CSV] as SummaryExports
    [Log files\n_logs] as Logs
}

package "Local Infrastructure" {
    [Docker Compose] as Docker
    [pgAdmin] as PgAdmin
}

CLI --> RunBaseline
CLI --> PopulateDb
CLI --> SummarizeRun

RunBaseline --> DefaultTest
DefaultTest --> TestOrchestrator : inherited run()
DefaultTest --> ChatbotStore : registers GPT-5 / GPT-4.1
DefaultTest --> VectorStore : shared RAG store

TestOrchestrator --> TestCases : execute()
TestOrchestrator --> Storage : save_test_run()

TestCases --> AttackBuilders : setup_attack_builder()\nsimulate_attacks()
TestCases --> AttackEnhancer : enhance()
TestCases --> ChatbotStore : get_chatbots()
TestCases --> LangChainChatbot : query()
TestCases --> DeepTeam : built-in metrics
TestCases --> DeepEval : custom GEval metrics
TestCases --> GuardrailRunner : run()
TestCases --> Storage : save_test_case_result()
TestCases --> OllamaGenerator : local model lifecycle

AttackBuilders --> DeepTeam : vulnerabilities + attack simulation
AttackBuilders --> CSVLoader : custom prompt loading
CSVLoader ..> CsvFiles : read CSV prompts

AttackEnhancer --> DeepTeam : built-in attack transforms
AttackEnhancer --> DeepEval : simulator model abstraction
AttackEnhancer --> OllamaGenerator : cooldown / shutdown / restart

GuardrailRunner --> PromptHardeningGuardrail
GuardrailRunner --> LLMGuard
GuardrailRunner --> LlamaFirewall
GuardrailRunner --> LakeraGuard
GuardrailRunner --> GuardrailsAI
GuardrailRunner --> GcpModelArmor

PromptHardeningGuardrail --> ChatbotStore : re-query same chatbot
PromptHardeningGuardrail --> DeepTeam : metric reuse
LLMGuard --> LLMGuardLib
LlamaFirewall --> LlamaFirewallLib
LakeraGuard --> LakeraAPI
GuardrailsAI --> GuardrailsAPI
GcpModelArmor --> GcpModelArmorAPI

LangChainChatbot --> LangChain
LangChainChatbot --> VectorStore : similarity_search()
LangChainChatbot --> AttackDocumentLoader : _load_document()
LangChainChatbot --> GenerateImage : optional tool call
LangChainChatbot --> OpenAI : model inference
AttackDocumentLoader --> PyPDFLoader
AttackDocumentLoader ..> AttackDocs : load PDFs

PopulateDb --> DocumentLoader
PopulateDb --> VectorStore : add_documents()
DocumentLoader --> PyPDFLoader
DocumentLoader ..> RagDocs : load PDFs

VectorStore --> PGVectorLib
VectorStore --> OpenAI : embeddings API
VectorStore --> Postgres : vector persistence

SummarizeRun --> RunSummary
RunSummary --> Storage : resolve run folder
RunSummary ..> TestcaseJson : read testcase JSON
RunSummary --> SummaryExports : write JSON + CSV

Storage --> RunResultJson
Storage --> TestcaseJson

RunBaseline ..> Logs
PopulateDb ..> Logs
SummarizeRun ..> Logs

Docker ..> Postgres : provisions service
Docker ..> PgAdmin : provisions service
Docker ..> GuardrailsAPI : optional local service
PgAdmin ..> Postgres : inspects DB

@enduml
