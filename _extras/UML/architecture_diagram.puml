@startuml
!theme plain
top to bottom direction
skinparam componentStyle rectangle

title LLM Chatbot Protection Framework - Runtime Architecture

package "CLI" {
'    [cli.main] as CLI
    [run-baseline] as RunBaseline
    [populate-db] as PopulateDb
    [summarize-run] as SummarizeRun
}

package "Test Run Orchestration" {
    [Test\n(abstract orchestrator)] as Test
    [DefaultTest\n(current baseline suite)] as DefaultTest
    [BaseTestCase + concrete suites] as TestCases
    [Attack Builders\n(CSV, DeepTeam, hybrid)] as AttackBuilders
    [AttackListEnhancer] as AttackEnhancer
    [ChatbotStore] as ChatbotStore
    [GuardrailRunner] as GuardrailRunner
    [PromptHardeningGuardrail] as PromptHardening
    [External Guardrails\n(LLM Guard, LlamaFirewall,\nLakera, Guardrails AI,\nGCP Model Armor)] as ExternalGuardrails
    [Storage] as Storage
    [RunSummary] as RunSummary
}

package "Execution Layer" {
    [LangChainChatbot] as LangChainChatbot
    [VectorStore] as VectorStore
    [DocumentLoader] as DocumentLoader
    [CSVLoader] as CSVLoader
    [OllamaGenerator] as OllamaGenerator
    [generate_image tool] as GenerateImage
}

package "External Libraries / Services" {
    [DeepTeam] as DeepTeam
    [DeepEval / GEval] as DeepEval
    [LangChain / ChatOpenAI] as LangChain
    [OpenAI API] as OpenAI
    [PGVector / langchain-postgres] as PGVectorLib
    [PyPDFLoader] as PyPDFLoader
    [llm-guard] as LLMGuardLib
    [LlamaFirewall] as LlamaFirewallLib
    [Lakera Guard API] as LakeraAPI
    [Guardrails AI service] as GuardrailsAPI
    [GCP Model Armor API] as GcpModelArmorAPI
    [PostgreSQL / pgvector] as Postgres
    [Ollama local model] as Ollama
}

database "Project Data" {
    [Prompt CSV files\n_prompt_files] as CsvFiles
    [Attack PDFs\n_attack_documents] as AttackDocs
    [RAG PDFs\n_rag_documents] as RagDocs
    [Run folder\n_runs/<run>] as RunFolder
    [Summary exports\nJSON + CSV] as SummaryExports
    [Log files\n_logs] as Logs
}

CLI --> RunBaseline
CLI --> PopulateDb
CLI --> SummarizeRun

RunBaseline --> DefaultTest
DefaultTest --> Test : inherits run()
DefaultTest --> VectorStore : shared RAG store
DefaultTest --> LangChainChatbot : registers GPT-5 / GPT-4.1

Test --> ChatbotStore : setup chatbots
Test --> TestCases : execute()
Test --> Storage : save_test_run()

TestCases --> AttackBuilders : setup + simulate attacks
TestCases --> AttackEnhancer : apply techniques
TestCases --> ChatbotStore : get_chatbots()
TestCases --> LangChainChatbot : query()
TestCases --> DeepTeam : built-in metrics
TestCases --> DeepEval : custom metrics
TestCases --> GuardrailRunner : run()
TestCases --> Storage : save_test_case_result()
TestCases --> OllamaGenerator : local model lifecycle

AttackBuilders --> CSVLoader : manual prompt loading
AttackBuilders --> DeepTeam : vulnerability generation
CSVLoader ..> CsvFiles : read

AttackEnhancer --> DeepTeam : single-turn attack transforms
AttackEnhancer --> OllamaGenerator : cooldown / shutdown
OllamaGenerator --> Ollama

GuardrailRunner --> PromptHardening
GuardrailRunner --> ExternalGuardrails
PromptHardening --> ChatbotStore : re-query same chatbot
PromptHardening --> LangChainChatbot : hardened prompt
ExternalGuardrails --> LLMGuardLib
ExternalGuardrails --> LlamaFirewallLib
ExternalGuardrails --> LakeraAPI
ExternalGuardrails --> GuardrailsAPI
ExternalGuardrails --> GcpModelArmorAPI

LangChainChatbot --> VectorStore : similarity_search()
LangChainChatbot --> PyPDFLoader : load attack PDFs
LangChainChatbot --> GenerateImage : optional tool call
LangChainChatbot --> LangChain : invoke model
LangChainChatbot --> OpenAI : inference
LangChainChatbot ..> AttackDocs : optional document source

PopulateDb --> DocumentLoader : load + split PDFs
PopulateDb --> VectorStore : add_documents()
DocumentLoader --> PyPDFLoader
DocumentLoader ..> RagDocs : read

VectorStore --> PGVectorLib
VectorStore --> OpenAI : embeddings API
VectorStore --> Postgres : vector persistence

SummarizeRun --> RunSummary
RunSummary ..> RunFolder : read testcase JSON
RunSummary --> SummaryExports : write JSON + CSV

Storage --> RunFolder : write result + testcase files

RunBaseline ..> Logs
PopulateDb ..> Logs
SummarizeRun ..> Logs

@enduml
