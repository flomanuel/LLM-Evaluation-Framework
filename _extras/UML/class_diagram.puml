package "testframework.models" as models_pkg {
    class TestErrorInfo <<dataclass>> {
        +error_type: LLMErrorType
        +message: str
        +timestamp: datetime
        {static} +from_exception(exc): TestErrorInfo
    }

    class PromptVariants <<dataclass>> {
        +baseline: str
        +enhanced: str
    }

    class ToolInfo <<dataclass>> {
        +tool_called: bool
        +tool_name: str | None
        +tool_args: dict | str | None
    }

    class RagContext <<dataclass>> {
        +embedding_model: str | None
        +nodes: List[str]
    }

    class DocumentContext <<dataclass>> {
        +document: str
    }

    class ChatbotResponse <<dataclass>> {
        +prompt: str
        +raw_prompt: str
        +response: str
        +system_prompt: str
        +tool: ToolInfo
        +prompt_tokens: int
        +response_tokens: int
        +rag_context: RagContext | None
        +document_content: DocumentContext | None
        +file_path: str | None
        +error: TestErrorInfo | None
        +is_error: bool
        {static} +from_error(error: TestErrorInfo, system_prompt: str = "", prompt: str = ""): ChatbotResponse
    }

    class ChatbotResponseEvaluation <<dataclass>> {
        +chatbot_response: ChatbotResponse
        +score: float
        +reason: str
        +success: bool
        +metric: str
        +error: TestErrorInfo | None
        +is_error: bool
        {static} +from_error(chatbot_response: ChatbotResponse, error: TestErrorInfo | None = None): ChatbotResponseEvaluation
    }

    class ScannerDetail <<dataclass>> {
        +name: str
        +score: float
        +reason: str
        +is_valid: bool | None
        +sanitized_input: str
    }

    class DetectionElement <<dataclass>> {
        +success: bool
        +detected_type: Category | str | None
        +score: float
        +judge_raw_response: str
        +latency: float | None
        +scanner_details: List[ScannerDetail]
        +error: TestErrorInfo | None
        +is_error: bool
        {static} +from_error(error: TestErrorInfo): DetectionElement
    }

    class PromptHardeningDetectionElement <<dataclass>> {
        +chatbot_response: ChatbotResponse | None
    }

    class DetectionResult <<dataclass>> {
        +input_detection: DetectionElement
        +output_detection: DetectionElement
    }

    class EnhancedAttack <<dataclass>> {
        +attack_case: RTTestCase
        +baseline_input: str
        +enhanced_input: str
        +techniques: List[str]
        +error: TestErrorInfo | None
        +is_error: bool
    }

    class AttackEnhancementResult <<dataclass>> {
        +enhanced_attacks: List[EnhancedAttack]
        +planned_attack_count: int
        +failed_attack_count: int
        +error_threshold_percent: float
        +stopped_early: bool
        +invalid_percentage: float
        +threshold_exceeded: bool
    }

    class Attack <<dataclass>> {
        +category: str
        +subcategory: Enum | None
        +techniques: List[str]
        +severity: Severity
        +prompt: PromptVariants
        +llm_responses: Dict[ChatbotName, ChatbotResponseEvaluation]
        +protection: Dict[str, Dict[ChatbotName, DetectionResult]]
        +error: TestErrorInfo | None
        +is_error: bool
        {static} +from_generation_error(category: str, subcategories: List[Enum] | None, severity: Severity, error: TestErrorInfo): Attack
        {static} +from_enhancement_error(category: str, subcategories: List[Enum] | None, severity: Severity, baseline_input: str, enhanced_input: str, techniques: List[str], error: TestErrorInfo): Attack
    }

    class "TestCaseResult.ModelInfo" as TestCaseResultModelInfo <<dataclass>> {
        +attack_and_vulnerability_generation: str | None
    }

    class TestCaseResult <<dataclass>> {
        +category: Category
        +subcategories: List[str]
        +model: TestCaseResult.ModelInfo
        +attacks: Dict[str, Attack]
        +generation_error: TestErrorInfo | None
        +enhancement_error: TestErrorInfo | None
        +identifier: str
        +has_errors: bool
        +error_count: int
    }

    class TestRunTimestamp <<dataclass>> {
        +start: datetime
        +end: datetime
    }

    class TestRunResult <<dataclass>> {
        +run_id: str
        +timestamp: TestRunTimestamp
        +attack_categories: List[TestCaseResult]
        +to_json_dict(): Dict[str, Any]
        {class} +new_empty(): TestRunResult
    }
}

package "testframework.tests" as tests_pkg {
    abstract class Test {
        +name: str
        +results_dir: Path
        +test_case_results: List[TestCaseResult]
        {abstract} +setup_chatbots(): None
        {abstract} +get_test_cases(): List[BaseTestCase]
        +run(): TestRunResult
        +store_test_run(test_run: TestRunResult): str
    }

    class DefaultTest extends Test {
        +setup_chatbots(): None
        +get_test_cases(): List[BaseTestCase]
    }
}

