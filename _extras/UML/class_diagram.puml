package "testframework.chatbots" as chatbots_pkg {
    abstract class BaseChatbot {
        +name: ChatbotName
        +prepare_for_test_case(): None
        +cleanup_after_test_case(): None
        {abstract} +query(user_prompt: str, is_rag: bool = True, file_path: str | None = None, system_prompt: str | None = None): ChatbotResponse
    }

    abstract class BaseLangChainChatbot extends BaseChatbot {
        +DEFAULT_TIMEOUT: float
        +DEFAULT_TIMEOUT_RETRIES: int
        +ATTACK_DOCUMENTS_FOLDER: Path
        +DEFAULT_SYSTEM_PROMPT: str
        +vector_store: VectorStore | None
        +query(user_prompt: str, is_rag: bool = True, file_path: str | None = None, system_prompt: str | None = None): ChatbotResponse
        {abstract} #_create_llm(model: str, timeout: float, **kwargs): Any
    }

    class LangChainChatbot extends BaseLangChainChatbot {
        #_create_llm(model: str, timeout: float, **kwargs): Any
    }

    class LangChainOllamaChatbot extends BaseLangChainChatbot {
        +DEFAULT_MODEL: str
        #_create_llm(model: str, timeout: float, **kwargs): Any
        +prepare_for_test_case(): None
        +cleanup_after_test_case(): None
    }

    class ChatbotStore {
        {static} +add_chatbot(chatbot: BaseChatbot): None
        {static} +remove_chatbot(name: ChatbotName): None
        {static} +get_chatbots(): Dict[ChatbotName, BaseChatbot]
        {static} +get_chatbot(name: ChatbotName): BaseChatbot | None
    }

    class VectorStore {
        +EMBEDDING_MODEL: str
        +COLLECTION_NAME: str
        +add_documents(documents: List[Document]): List[str]
        +similarity_search(query: str, k: int): List[Document]
        +embeddings: OpenAIEmbeddings
        +embedding_model_name: str
    }
}

package "llamafirewall (external dependency)" as llamafirewall {
    class LlamaFirewall
}

package "testframework.guardrails" as guardrails_pkg {
    abstract class BaseGuardrail {
        +name: str
        {abstract} +eval_attack(user_prompt: str, **kwargs): DetectionElement
        {abstract} +eval_model_response(model_response: str, chatbot: ChatbotName, **kwargs): DetectionElement
    }

    class PromptHardeningGuardrail extends BaseGuardrail {
        +eval_attack(user_prompt: str, **kwargs): PromptHardeningDetectionElement
        +eval_model_response(prompt: str, chatbot: ChatbotName, **kwargs): PromptHardeningDetectionElement
    }

    class LLMGuard extends BaseGuardrail
    class LlamaFirewall extends BaseGuardrail
    class LlamaFirewallWithMetrics extends llamafirewall.LlamaFirewall {
        +scan(input_msg: Message, trace: Trace | None = None): Dict[str, List[ScannerDetail] | ScanResult]
    }
    class LakeraGuard extends BaseGuardrail
    class GuardrailsAI extends BaseGuardrail
    class GcpModelArmor extends BaseGuardrail

    class GuardrailRunner {
        +guardrails: List[BaseGuardrail]
        +run(attack: RTTestCase, chatbot_responses_eval: dict[ChatbotName, ChatbotResponseEvaluation], metric: BaseRedTeamingMetric): Dict[str, Dict[ChatbotName, DetectionResult]]
    }
}

package "testframework.metrics" as metrics_pkg {
    abstract class BaseMetric {
        +harm_category: str
        #_transfer_results_from_geval(): None
    }

    class PrivacyViolationsMetric extends BaseMetric {
        +DEFAULT_CRITERIA: str
        +is_successful(): bool
        +measure(test_case: RTTestCase, *args, **kwargs): float
    }

    class ToolCallCodeInjectionMetric extends BaseMetric {
        +DEFAULT_CRITERIA: str
        +is_successful(): bool
        +measure(test_case: RTTestCase, tool_info: ToolInfo | None = None, *args, **kwargs): float
    }
}
package "testframework.custom_attack_techniques" as attack_techniques_pkg {
    class AttackEnhancement <<dataclass>> {
        +name: str
        +transform: Callable
        +cooldown: Callable
    }

    class AttackListEnhancer {
        +ERROR_THRESHOLD_ENV_VAR: str
        +DEFAULT_ERROR_THRESHOLD_PERCENT: float
        +ERROR_RETRY_COOLDOWN_SECONDS: int
        +ATTACK_GENERATION_COOLDOWN_SECONDS: int
        +SUCCESS_COOLDOWN_SECONDS: int
        +LOCAL_MODEL_ID: str | bool
        +simulator_model: DeepEvalBaseLLM | str | None
        +enhance(attacks: List[RTTestCase], enhancements: List[AttackEnhancement] | None = None): AttackEnhancementResult
    }

    class Techniques <<module>> {
        {static} +TECHNIQUE_BASELINE: str
        {static} +ENHANCEMENTS: List[AttackEnhancement]
    }

    package "cipher_code_expert" as cipher_pkg {
        class CipherCodeExpert {
            +name: str
            +exploitability: Exploitability
            +description: str
            +enhance(attack: str, *args, **kwargs): str
            +get_name(): str
        }

        class CipherCodeExpertTemplate {
            +BASE_DESCRIPTION: str
            {static} +enhance(input: str): str
        }
    }
}

