@startuml
!theme plain
skinparam componentStyle rectangle
skinparam rectangle {
    BackgroundColor<<Category>> #E8EEF5
    BorderColor<<Category>> #5A6B7A
    FontStyle bold
}

title LLM Chatbot Protection Framework - Source-Aligned Technology Stack

rectangle "Project Technology Stack" {

    rectangle "Runtime & Core Utilities" <<Category>> {
        [Python ~=3.13] as Python
        [argparse (stdlib CLI)] as Argparse
        [python-dotenv ~=1.2.1] as Dotenv
        [Loguru ~=0.7.0] as Loguru
    }

    rectangle "LLM, Evaluation, and Attack Generation" <<Category>> {
        [OpenAI SDK ~=2.24.0] as OpenAISDK
        [OpenAI API] as OpenAIAPI
        [Ollama SDK ~=0.6.1] as Ollama
        [DeepTeam ~=1.0.5] as DeepTeam
        [DeepEval ~=3.8.8] as DeepEval
    }

    rectangle "Chatbot Orchestration & RAG" <<Category>> {
        [LangChain ~=1.2.10] as LangChain
        [langchain-openai ~=1.1.10] as LangChainOpenAI
        [langchain-postgres ~=0.0.17] as LangChainPostgres
        [langchain-community ~=0.4.1] as LangChainCommunity
        [langchain-text-splitters ~=1.1.1] as LangChainSplitters
        [pypdf ~=6.7.3] as PyPDF
    }

    rectangle "Persistence & Local Infrastructure" <<Category>> {
        [PostgreSQL] as Postgres
        [pgvector image (pg16)] as Pgvector
        [psycopg[binary] ~=3.3.3] as Psycopg
        [Docker Compose] as Docker
        [pgAdmin 4] as PgAdmin
    }

    rectangle "Developer Tooling" <<Category>> {
        [uv] as UV
        [PlantUML] as PlantUML
        [Flake8 ~=7.3.0] as Flake8
        [Pylint ~=4.0.5] as Pylint
        [Bandit ~=1.9.4] as Bandit
        [OpenTelemetry OTLP ~=1.39.1\n(declared dependency)] as OTLP
    }
}

Python ..> Argparse : stdlib CLI
Python ..> Dotenv : environment loading
Python ..> Loguru : logging

DeepTeam ..> DeepEval : model abstractions + metrics
DeepEval ..> Ollama : local simulator usage

LangChain ..> LangChainOpenAI : ChatOpenAI + embeddings
LangChain ..> LangChainPostgres : PGVector integration
LangChain ..> LangChainCommunity : PyPDFLoader
LangChain ..> LangChainSplitters : chunking
LangChainCommunity ..> PyPDF : PDF parsing
LangChainOpenAI ..> OpenAIAPI : remote calls
OpenAISDK ..> OpenAIAPI : API client dependency

LangChainPostgres ..> Psycopg : database driver
LangChainPostgres ..> Postgres : vector persistence
Postgres ..> Pgvector : vector extension image
Docker ..> Postgres : local service
Docker ..> PgAdmin : local service

UV ..> Python : environment + dependency management

@enduml
